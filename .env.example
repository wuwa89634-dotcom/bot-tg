BOT_TOKEN=123456:telegram_bot_token

# Club binding.
CLUB_URL=https://mangabuff.ru/clubs/fu-razvrat
CLUB_SLUG=fu-razvrat
TIMEZONE=Europe/Moscow

# Main menu content. Leave MENU_PHOTO_PATH empty to send text only.
MENU_PHOTO_PATH=
MENU_TEXT=Текст главного меню. Его можно заменить в .env.
GUIDE_TEXT=Короткий гайд: нажмите «Запись на вклады», выберите свободное время на сегодня или завтра.

# Optional chat schedule publishing.
# Add bot to your Telegram chat/topic and run /post_schedule there.
# The bot stores the chat, topic, and message IDs automatically.
GROUP_CHAT_ID=
SCHEDULE_MESSAGE_ID=
SCHEDULE_THREAD_ID=

DB_PATH=bot.db
