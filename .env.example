BOT_TOKEN=123456:telegram_bot_token

CHAT_URL=https://t.me/your_chat_or_topic
TIMEZONE=Europe/Moscow
# Separate multiple IDs with commas, spaces, semicolons, or new lines.
ADMIN_IDS=123456789,987654321

# Main menu content. Set MENU_PHOTO_PATH empty to send text only.
MENU_PHOTO_PATH=assets/menu.jpg
MENU_TEXT=[ Гений, миллиардер и просто красивый мужчина: @reeigans]\n\nВас приветствует бот клуба "Keepers of Oneiroi" Он создан для вашего удобства и слаженной работы над клубом.
GUIDE_TEXT=Короткий гайд: нажмите «Запись на вклады», выберите свободное время на сегодня или завтра.

# Optional chat schedule publishing.
# Add bot to your Telegram chat/topic and run /post_schedule there.
# The bot stores the chat, topic, and message IDs automatically.
GROUP_CHAT_ID=
SCHEDULE_MESSAGE_ID=
SCHEDULE_THREAD_ID=

# Railway PostgreSQL provides DATABASE_URL automatically after you connect the database.
DATABASE_URL=
DB_PATH=bot.db
